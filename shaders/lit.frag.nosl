
Data :: struct
{
    base_color_map: texture_id,
    base_color_map_sampler: sampler_id,

    metallic_roughness_map: texture_id,
    metallic_roughness_map_sampler: sampler_id,

    normal_map: texture_id,
    normal_map_sampler: sampler_id,

    lightmap: texture_id,
    lightmap_sampler: sampler_id,
    do_bicubic_sampling: bool,
    sample_lightmap: bool,
    sample_diffuse: bool,

    select_lm_pixel: bool,
    selected_lm_pixel: vec2,
}

PI: float = 3.14159265359;

main :: (normal_vert: vec4 @input(0), uv: vec2 @input(1), lm_uv: vec2 @input(2), world_pos: vec4 @input(3), data: ^Data @data) -> vec4 @output(0)
{
    // Sample base color texture
    base_color := texture_sample(data.base_color_map, data.base_color_map_sampler, uv);
    // Trick to get crisp AA on foliage.
    base_color.a = (base_color.a - 0.3) / max(fwidth_(base_color.a), 0.0001) + 0.5;

    // Sample normal map and transform to world space
    // TODO: Properly transform normal map from tangent space to world space
    normal_map_sample := texture_sample(data.normal_map, data.normal_map_sampler, uv);
    // For now, use vertex normal (normal_map_sample would need tangent/bitangent)
    world_normal := normalize(normal_vert.xyz);
    // Pack normal into RGB (0.5 + 0.5 * normal to map from [-1,1] to [0,1])
    packed_normal := vec4(world_normal * 0.5 + 0.5, 1.0);

    // Sample metallic/roughness texture
    metallic_roughness_sample := texture_sample(data.metallic_roughness_map, data.metallic_roughness_map_sampler, uv);

    irradiance: vec3;
    if data.do_bicubic_sampling {
        lm_sample := texture_sample_bicubic(data.lightmap, data.lightmap_sampler, lm_uv);
        irradiance = lm_sample.rgb;
        if lm_sample.a < 0.5 {
            return vec4(0, 0, 1, 1);
        }
    } else {
        lm_sample := texture_sample(data.lightmap, data.lightmap_sampler, lm_uv);
        irradiance = lm_sample.rgb;
        if lm_sample.a < 0.5 {
            return vec4(0, 0, 1, 1);
        }
    }

    out := vec3(1);
    if data.sample_diffuse && data.sample_lightmap {
        out = base_color.rgb / PI * irradiance;
    } else if data.sample_diffuse && !data.sample_lightmap {
        out = base_color.rgb;
    } else if !data.sample_diffuse && data.sample_lightmap {
        out = irradiance;
    }

    if data.select_lm_pixel
    {
        lm_size := texture_size(data.lightmap, data.lightmap_sampler, 0);
        texel := lm_size * lm_uv;
        if texel.x >= data.selected_lm_pixel.x && texel.x <= data.selected_lm_pixel.x + 1 &&
           texel.y >= data.selected_lm_pixel.y && texel.y <= data.selected_lm_pixel.y + 1 {
            out = vec3(1, 0, 1);
        }
    }

    return vec4(out, base_color.a);
}

fwidth_ :: (v: float) -> float
{
    return abs(dfdx_fine(v)) + abs(dfdy_fine(v));
}

cubic :: (v: float) -> vec4
{
    n := vec4(1.0, 2.0, 3.0, 4.0) - v;
    s := n * n * n;
    x := s.x;
    y := s.y - 4.0 * s.x;
    z := s.z - 4.0 * s.y + 6.0 * s.x;
    w := 6.0 - x - y - z;
    return vec4(x, y, z, w) * (1.0/6.0);
}

// From: https://stackoverflow.com/questions/13501081/efficient-bicubic-filtering-code-in-glsl
texture_sample_bicubic :: (texture: texture_id, linear_sampler: sampler_id, coords: vec2) -> vec4
{
    tex_size := texture_size(texture, linear_sampler, 0);
    inv_tex_size := 1.0 / tex_size;

    tex_coords := coords * tex_size - 0.5;

    fxy := fract(tex_coords);
    tex_coords -= fxy;

    xcubic := cubic(fxy.x);
    ycubic := cubic(fxy.y);

    c := tex_coords.xxyy + vec2 (-0.5, +1.5).xyxy;

    s := vec4(xcubic.xz + xcubic.yw, ycubic.xz + ycubic.yw);
    offset := c + vec4 (xcubic.yw, ycubic.yw) / s;

    offset *= inv_tex_size.xxyy;

    sample0 := texture_sample(texture, linear_sampler, offset.xz);
    sample1 := texture_sample(texture, linear_sampler, offset.yz);
    sample2 := texture_sample(texture, linear_sampler, offset.xw);
    sample3 := texture_sample(texture, linear_sampler, offset.yw);

    sx := s.x / (s.x + s.y);
    sy := s.z / (s.z + s.w);

    return mix(mix(sample3, sample2, vec4(sx)), mix(sample1, sample0, vec4(sx)), vec4(sy));
}
