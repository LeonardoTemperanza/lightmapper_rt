
Output :: struct
{
    out_pos: vec4 @position,
    world_pos: vec3 @out_loc(0),
    world_normal: vec3 @out_loc(1),
    uv: vec2 @out_loc(2),
}

Data :: struct
{
    pos: []vec3,
    normals: []vec3,
    uvs: []vec2,
    lightmap_uvs: []vec2,
    resolution: vec2,
    model_to_world: mat4,
    model_to_world_normals: mat4,
}

main :: (vert_id: uint @vert_id, instance_id: uint @instance_id, data: ^Data @data) -> Output
{
    // Simulate conservative rasterization
    offsets: [25]vec2;
    offsets[0]  = vec2(-2.0, -2.0);
    offsets[1]  = vec2(2.0, -2.0);
    offsets[2]  = vec2(-2.0, 2.0);
    offsets[3]  = vec2(2.0, 2.0);
    offsets[4]  = vec2(-1.0, -2.0);
    offsets[5]  = vec2(1.0, -2.0);
    offsets[6]  = vec2(-2.0, -1.0);
    offsets[7]  = vec2(2.0, -1.0);
    offsets[8]  = vec2(-2.0, 1.0);
    offsets[9]  = vec2(2.0, 1.0);
    offsets[10] = vec2(-1.0, 2.0);
    offsets[11] = vec2(1.0, 2.0);
    offsets[12] = vec2(-2.0, 0.0);
    offsets[13] = vec2(2.0, 0.0);
    offsets[14] = vec2(0.0, -2.0);
    offsets[15] = vec2(0.0, 2.0);
    offsets[16] = vec2(-1.0, -1.0);
    offsets[17] = vec2(1.0, -1.0);
    offsets[18] = vec2(-1.0, 0.0);
    offsets[19] = vec2(1.0, 0.0);
    offsets[20] = vec2(-1.0, 1.0);
    offsets[21] = vec2(1.0, 1.0);
    offsets[22] = vec2(0.0, -1.0);
    offsets[23] = vec2(0.0, 1.0);
    offsets[24] = vec2(0.0, 0.0);

    uv_offset := offsets[instance_id % 25];
    ndc_offset := (uv_offset / data.resolution) / 2.0;

    vert_out: Output;
    vert_out.out_pos = vec4((data.lightmap_uvs[vert_id] * 2 - 1) + ndc_offset, 0, 1);
    vert_out.world_pos = (data.model_to_world * vec4(data.pos[vert_id], 1)).xyz;
    vert_out.world_normal = (data.model_to_world_normals * vec4(data.normals[vert_id], 0)).xyz;
    vert_out.uv = data.uvs[vert_id];
    return vert_out;
}
