
Data :: struct
{
    verts: []vec2,
    scale: vec2,
    translate: vec2,
}

Output :: struct
{
    pos: vec4 @position,
}

main :: (data: ^Data @data, vert_id: uint @vert_id) -> Output
{
    uv := data.verts[vert_id];

    out: Output;
    out.pos = vec4(uv * data.scale + data.translate, 0, 1);
    return out;
}
